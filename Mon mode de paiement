export default function handler(req, res) {
  const { business } = JSON.parse(req.body);

  const content = `
🔥 Nouveau post pour ${business} :

"Envie de changement ? ✂️✨
Chez ${business}, on vous offre une expérience unique !
Réservez dès maintenant 💇‍♀️🔥

#business #local #promotion"
  `;

  res.status(200).json({ content });
}
